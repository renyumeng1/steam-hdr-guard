<Window x:Class="SteamHdrGuard.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam HDR Guard"
        Width="1120"
        Height="780"
        MinWidth="960"
        MinHeight="620"
        Background="#F5F5F7"
        FontFamily="Segoe UI Variable, Segoe UI, Microsoft YaHei UI"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" />
        <SolidColorBrush x:Key="PrimaryText" Color="#1D1D1F" />
        <SolidColorBrush x:Key="SecondaryText" Color="#6E6E73" />
        <SolidColorBrush x:Key="Hairline" Color="#E5E5EA" />
        <SolidColorBrush x:Key="Accent" Color="#007AFF" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="AppleButton" TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#F8F8FA" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#D2D2D7" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource AppleButton}">
            <Setter Property="Background" Value="{StaticResource Accent}" />
            <Setter Property="BorderBrush" Value="{StaticResource Accent}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
            <Setter Property="Margin" Value="0,4,18,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="BorderBrush" Value="{StaticResource Hairline}" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowBackground" Value="#FFFFFF" />
            <Setter Property="AlternatingRowBackground" Value="#FAFAFC" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="EnableRowVirtualization" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="True" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryText}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="BorderBrush" Value="#EFEFF4" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="BorderBrush" Value="#EFEFF4" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F9FF" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EAF3FF" />
                    <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Steam HDR Guard" FontSize="30" FontWeight="SemiBold" />
                <TextBlock x:Name="ConfigPathText" Style="{StaticResource MutedText}" Margin="1,6,0,0" />
            </StackPanel>
            <Border Grid.Column="1" Background="#111111" CornerRadius="18" Width="56" Height="56" HorizontalAlignment="Right">
                <Grid>
                    <Ellipse Width="34" Height="34" Stroke="#FFFFFF" StrokeThickness="1.6" />
                    <TextBlock Text="HDR" Foreground="#FFFFFF" FontWeight="SemiBold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,2,0">
                <StackPanel>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="控制" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="安静地监控游戏，只在需要时切换 HDR。" Style="{StaticResource MutedText}" Margin="0,4,0,16" />
                            <Button x:Name="StartButton" Content="开始监控" Style="{StaticResource PrimaryButton}" Margin="0,0,0,8" Click="StartButton_Click" />
                            <Button x:Name="StopButton" Content="停止监控" Style="{StaticResource AppleButton}" Margin="0,0,0,8" Click="StopButton_Click" IsEnabled="False" />
                            <Button x:Name="ScanButton" Content="扫描 Steam 游戏" Style="{StaticResource AppleButton}" Margin="0,0,0,8" Click="ScanButton_Click" />
                            <Button x:Name="SaveButton" Content="保存配置" Style="{StaticResource AppleButton}" Margin="0" Click="SaveButton_Click" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="偏好设置" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="这些设置会保存到本地配置。" Style="{StaticResource MutedText}" Margin="0,4,0,14" />
                            <TextBlock Text="游戏退出后关闭 HDR 延迟（秒）" Style="{StaticResource MutedText}" />
                            <TextBox x:Name="ExitDelayBox" Width="96" HorizontalAlignment="Left" Margin="0,6,0,12" />
                            <CheckBox x:Name="StartupCheckBox" Content="开机自启 GUI" Checked="StartupCheckBox_Changed" Unchecked="StartupCheckBox_Changed" />
                            <CheckBox x:Name="AutoStartMonitoringCheckBox" Content="启动后自动开始监控" />
                            <CheckBox x:Name="MinimizeToTrayCheckBox" Content="关闭窗口时最小化到托盘" />
                            <CheckBox x:Name="RestorePreviousCheckBox" Content="退出游戏后恢复原 HDR 状态" />
                            <TextBlock x:Name="SettingsStatusText" Style="{StaticResource MutedText}" Margin="0,10,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="HDR 状态提示" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="切换 HDR 后等待屏幕重新亮起，再显示短暂悬浮提示。" Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,4,0,14" />
                            <CheckBox x:Name="HdrToastEnabledCheckBox" Content="启用 HDR 切换提示" />

                            <TextBlock Text="文案预设" Style="{StaticResource MutedText}" Margin="0,8,0,4" />
                            <ComboBox x:Name="HdrToastPresetBox" SelectedValuePath="Tag" SelectionChanged="HdrToastPresetBox_SelectionChanged">
                                <ComboBoxItem Content="简洁：HDR ON / HDR OFF" Tag="compact" />
                                <ComboBoxItem Content="中文：HDR 已开启 / HDR 已关闭" Tag="chinese" />
                                <ComboBoxItem Content="自定义" Tag="custom" />
                            </ComboBox>

                            <TextBlock Text="提示位置" Style="{StaticResource MutedText}" Margin="0,10,0,4" />
                            <ComboBox x:Name="HdrToastPositionBox" SelectedValuePath="Tag">
                                <ComboBoxItem Content="顶部居中" Tag="top-center" />
                                <ComboBoxItem Content="屏幕中央" Tag="center" />
                                <ComboBoxItem Content="底部居中" Tag="bottom-center" />
                                <ComboBoxItem Content="左上角" Tag="top-left" />
                                <ComboBoxItem Content="右上角" Tag="top-right" />
                                <ComboBoxItem Content="左下角" Tag="bottom-left" />
                                <ComboBoxItem Content="右下角" Tag="bottom-right" />
                            </ComboBox>

                            <TextBlock Text="开启文案" Style="{StaticResource MutedText}" Margin="0,10,0,4" />
                            <TextBox x:Name="HdrToastOnTextBox" />
                            <TextBlock Text="关闭文案" Style="{StaticResource MutedText}" Margin="0,10,0,4" />
                            <TextBox x:Name="HdrToastOffTextBox" />
                            <TextBlock Text="切换后等待亮屏延迟（毫秒）" Style="{StaticResource MutedText}" Margin="0,10,0,4" />
                            <TextBox x:Name="HdrToastDelayBox" Width="96" HorizontalAlignment="Left" />
                            <TextBlock Text="显示时间（毫秒）" Style="{StaticResource MutedText}" Margin="0,10,0,4" />
                            <TextBox x:Name="HdrToastDurationBox" Width="96" HorizontalAlignment="Left" />
                            <Button Content="测试提示" Style="{StaticResource AppleButton}" Margin="0,12,0,0" Click="TestToastButton_Click" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="HDR" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="手动测试系统 HDR 开关。" Style="{StaticResource MutedText}" Margin="0,4,0,14" />
                            <WrapPanel>
                                <Button Content="HDR 开" Style="{StaticResource AppleButton}" Click="HdrOnButton_Click" />
                                <Button Content="HDR 关" Style="{StaticResource AppleButton}" Click="HdrOffButton_Click" />
                            </WrapPanel>
                            <Button Content="刷新显示器" Style="{StaticResource AppleButton}" Margin="0,10,0,0" Click="RefreshDisplaysButton_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2.2*" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="1.1*" />
                    <RowDefinition Height="14" />
                    <RowDefinition Height="1.15*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Steam 游戏" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="勾选需要启动时自动开启 HDR 的游戏。" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                        </StackPanel>
                        <DataGrid Grid.Row="1" x:Name="GamesGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="" Width="38" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Width="24" Height="24" CornerRadius="7" Background="#F2F2F7" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Image Source="{Binding Icon}" Width="18" Height="18" Stretch="Uniform" SnapsToDevicePixels="True" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridCheckBoxColumn Header="HDR" Binding="{Binding HdrEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" />
                                <DataGridTextColumn Header="AppID" Binding="{Binding AppId}" IsReadOnly="True" Width="88" />
                                <DataGridTextColumn Header="游戏名称" Binding="{Binding Name}" IsReadOnly="True" Width="230" />
                                <DataGridTextColumn Header="安装路径" Binding="{Binding InstallPath}" IsReadOnly="True" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="显示器" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock Text="读取 Windows Advanced Color 状态。" Style="{StaticResource MutedText}" Margin="0,4,0,0" />
                        </StackPanel>
                        <DataGrid Grid.Row="1" x:Name="DisplaysGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="显示器" Binding="{Binding MonitorName}" Width="*" />
                                <DataGridCheckBoxColumn Header="支持" Binding="{Binding AdvancedColorSupported}" Width="72" />
                                <DataGridCheckBoxColumn Header="已开" Binding="{Binding AdvancedColorEnabled}" Width="72" />
                                <DataGridCheckBoxColumn Header="强制禁用" Binding="{Binding AdvancedColorForceDisabled}" Width="92" />
                                <DataGridTextColumn Header="位深" Binding="{Binding BitsPerColorChannel}" Width="64" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="日志" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <TextBox Grid.Row="1" x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#FAFAFC" BorderBrush="#EFEFF4" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
