<Window x:Class="SteamHdrGuard.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Steam HDR Guard"
        Width="980"
        Height="680"
        MinWidth="860"
        MinHeight="560">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Vertical">
            <TextBlock Text="Steam HDR Guard" FontSize="22" FontWeight="SemiBold" />
            <TextBlock x:Name="ConfigPathText" Margin="0,4,0,8" Foreground="Gray" />
            <WrapPanel Margin="0,0,0,8">
                <Button x:Name="ScanButton" Content="扫描 Steam 游戏" Margin="0,0,8,0" Padding="12,6" Click="ScanButton_Click" />
                <Button x:Name="SaveButton" Content="保存配置" Margin="0,0,8,0" Padding="12,6" Click="SaveButton_Click" />
                <Button x:Name="StartButton" Content="开始监控" Margin="0,0,8,0" Padding="12,6" Click="StartButton_Click" />
                <Button x:Name="StopButton" Content="停止监控" Margin="0,0,8,0" Padding="12,6" Click="StopButton_Click" IsEnabled="False" />
                <Button Content="HDR 开" Margin="0,0,8,0" Padding="12,6" Click="HdrOnButton_Click" />
                <Button Content="HDR 关" Margin="0,0,8,0" Padding="12,6" Click="HdrOffButton_Click" />
                <Button Content="刷新显示器" Padding="12,6" Click="RefreshDisplaysButton_Click" />
            </WrapPanel>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="1.1*" />
            </Grid.RowDefinitions>

            <GroupBox Grid.Row="0" Header="Steam 游戏">
                <DataGrid x:Name="GamesGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" Margin="6">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Header="启用 HDR" Binding="{Binding HdrEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="90" />
                        <DataGridTextColumn Header="AppID" Binding="{Binding AppId}" IsReadOnly="True" Width="90" />
                        <DataGridTextColumn Header="游戏名称" Binding="{Binding Name}" IsReadOnly="True" Width="220" />
                        <DataGridTextColumn Header="安装路径" Binding="{Binding InstallPath}" IsReadOnly="True" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Row="1" Header="显示器 HDR 状态" Margin="0,8,0,0">
                <DataGrid x:Name="DisplaysGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" Margin="6">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="显示器" Binding="{Binding MonitorName}" Width="*" />
                        <DataGridCheckBoxColumn Header="支持 HDR" Binding="{Binding AdvancedColorSupported}" Width="90" />
                        <DataGridCheckBoxColumn Header="HDR 已开" Binding="{Binding AdvancedColorEnabled}" Width="90" />
                        <DataGridCheckBoxColumn Header="强制禁用" Binding="{Binding AdvancedColorForceDisabled}" Width="90" />
                        <DataGridTextColumn Header="位深" Binding="{Binding BitsPerColorChannel}" Width="70" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Grid.Row="2" Header="日志" Margin="0,8,0,0">
                <TextBox x:Name="LogBox" Margin="6" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
            </GroupBox>
        </Grid>
    </DockPanel>
</Window>
