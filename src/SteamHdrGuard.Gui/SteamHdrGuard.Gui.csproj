<Project Sdk="Microsoft.NET.Sdk">
  <ItemGroup>
    <ProjectReference Include="..\SteamHdrGuard.Core\SteamHdrGuard.Core.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>SteamHdrGuard.Gui</AssemblyName>
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
  </PropertyGroup>

  <PropertyGroup>
    <AppIconBase64></AppIconBase64>
  </PropertyGroup>

  <Target Name="GenerateAppIcon" BeforeTargets="PrepareForBuild">
    <MakeDir Directories="Assets" />
    <WriteLinesToFile File="Assets\app.ico.b64" Lines="$(AppIconBase64)" Overwrite="true" />
    <Exec Command="powershell -NoProfile -ExecutionPolicy Bypass -Command &quot;[IO.File]::WriteAllBytes('$(MSBuildProjectDirectory)\Assets\app.ico',[Convert]::FromBase64String((Get-Content '$(MSBuildProjectDirectory)\Assets\app.ico.b64' -Raw)))&quot;" />
  </Target>
</Project>
